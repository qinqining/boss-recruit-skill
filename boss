#!/usr/bin/env python3
"""
Boss Recruit CLI - 招聘方自动化入口
用法：
  python boss login                    # 登录
  python boss search                   # 搜索牛人
  python boss greet --top 10          # 打招呼前筛选
  python boss monitor --interval 30   # 消息监控
  python boss run --keywords SEO      # 一键运行
"""

import sys
import subprocess

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]

    scripts_dir = __file__.replace("\\", "/").rsplit("/", 1)[0] + "/scripts"

    if cmd == "login":
        subprocess.run([sys.executable, f"{scripts_dir}/login.py"])

    elif cmd == "search":
        pages = sys.argv[2] if len(sys.argv) > 2 else "2"
        subprocess.run([sys.executable, f"{scripts_dir}/search_talent.py", "--pages", pages])

    elif cmd == "greet":
        top = sys.argv[2] if len(sys.argv) > 2 else "10"
        subprocess.run([sys.executable, f"{scripts_dir}/greet.py", "--top", top])

    elif cmd == "monitor":
        interval = sys.argv[2] if len(sys.argv) > 2 else "30"
        subprocess.run([sys.executable, f"{scripts_dir}/chat_auto.py", "--interval", interval])

    elif cmd == "run":
        keywords = sys.argv[2] if len(sys.argv) > 2 else "SEO"
        top = sys.argv[3] if len(sys.argv) > 3 else "5"
        subprocess.run([sys.executable, f"{scripts_dir}/run_pipeline.py", "--keywords", keywords, "--top", top])

    else:
        print(f"未知命令: {cmd}")
        print(__doc__)
        sys.exit(1)

if __name__ == "__main__":
    main()