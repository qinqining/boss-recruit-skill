#!/usr/bin/env python3
"""
Boss Recruit CLI - 招聘方自动化入口（技能根目录下执行）
用法（Windows 推荐 py 启动器，避免未配置 python/python3）：
  py boss login                       # 登录
  py boss search                     # 搜索牛人（默认 --pages 2）
  py boss greet                       # 同上，默认最多成功打招呼 20 人（可 BOSS_GREET_TOP=30）
  py boss greet --top 15               # 自定义上限
  py boss greet --no-report            # 不写判定报告
  py boss followup [--max 5]        # 沟通列表「继续沟通」智能跟进（与 greet 同 profile）
  py boss followup --dry-run         # 只打印将发送的文案
  py boss run --keywords SEO        # 一键运行
"""

import sys
import subprocess
from pathlib import Path


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]
    scripts_dir = Path(__file__).resolve().parent / "scripts"

    if cmd == "login":
        subprocess.run([sys.executable, str(scripts_dir / "login.py")])

    elif cmd == "search":
        extra = sys.argv[2:] if len(sys.argv) > 2 else ["--pages", "2"]
        subprocess.run([sys.executable, str(scripts_dir / "search_talent.py")] + extra)

    elif cmd == "greet":
        extra = sys.argv[2:] if len(sys.argv) > 2 else []
        subprocess.run([sys.executable, str(scripts_dir / "greet.py")] + extra)

    elif cmd == "monitor":
        print(
            "[boss] 「monitor」已移除（原 chat_auto.py 已删除）。"
            "请使用：py boss followup [--max N] [--dry-run]",
            file=sys.stderr,
        )
        sys.exit(2)

    elif cmd == "followup":
        extra = sys.argv[2:] if len(sys.argv) > 2 else []
        subprocess.run([sys.executable, str(scripts_dir / "chat_followup.py")] + extra)

    elif cmd == "run":
        extra = sys.argv[2:] if len(sys.argv) > 2 else ["--keywords", "SEO", "--top", "5"]
        subprocess.run([sys.executable, str(scripts_dir / "run_pipeline.py")] + extra)

    else:
        print(f"未知命令: {cmd}")
        print(__doc__)
        sys.exit(1)

if __name__ == "__main__":
    main()